# Optional — without OPENAI_API_KEY the planner skips LLM fallback and responses use templates.
OPENAI_API_KEY=

# LLM settings
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=30
OPENAI_MAX_RETRIES=1

# Planner — below this confidence, the LLM classifier may run (if API key is set).
PLANNER_CONFIDENCE_THRESHOLD=0.67

# Optional — freeze time for stable evals (YYYY-MM-DD or ISO datetime).
# MOCK_REFERENCE_DATE=2026-06-01

# Risk — orders above this total (USD) trigger escalation.
RISK_HIGH_VALUE_USD=500
